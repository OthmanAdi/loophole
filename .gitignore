# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
out/
*.tsbuildinfo

# Docs site (standalone npm project under docs/, NOT a pnpm workspace member).
# node_modules/ and dist/ above already cover docs/node_modules and docs/dist;
# .astro is Astro's content-layer + types cache (also at docs/node_modules/.astro).
# The generated docs/src/data/tools.json is committed on purpose: the prebuild
# regenerates it and a CI guard (git diff --exit-code) fails on a stale copy.
.astro/

# Test / coverage
coverage/
.nyc_output/
*.lcov

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env / secrets (never commit real values)
.env
.env.*
!.env.example
.loophole/
bridge.json

# Ableton Extensions SDK beta packages: do NOT redistribute the beta .tgz publicly.
# Contributors fetch their own from the Ableton Beta Program (Centercode).
packages/extension/vendor/*.tgz

# Local-only SDK typecheck config: maps @ableton-extensions/sdk to a contributor's
# own extracted .d.mts (an absolute machine path) so the adapter typechecks against
# the real beta types. Never committed (keeps the tree SDK-free + path-portable).
packages/extension/tsconfig.live.json

# Packaged extension build artifacts (shipped via GitHub Releases, not the tree)
*.ablx

# Agent session artifacts: handoffs, planning, scratch, local agent config (never commit)
.agents/
.claude/settings.local.json
task_plan.md
findings.md
progress.md
*HANDOFF*.md
*.handoff.md

# Editor / OS
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
.DS_Store
Thumbs.db

# Internal launch strategy: staging only, must never be public
launch/
