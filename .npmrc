# pnpm config. Supply-chain hardening per the project npm policy (Shai-Hulud):
# pnpm 10 already blocks dependency lifecycle scripts by default (allowlist via
# pnpm.onlyBuiltDependencies in package.json). Keep this file minimal.
# engines fields stay as honest documentation; local dev is Node 22+. The
# extension's real Node 24.14.1 need is enforced by the Ableton SDK CLI later,
# not by pnpm. Strict engine checks here would block install on Node 22/24.x.
engine-strict=false
# Reproducible installs: refuse to silently rewrite the lockfile in CI.
# (CI passes --frozen-lockfile explicitly once a lockfile is committed.)
auto-install-peers=true
